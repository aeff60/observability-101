{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Observability Workshop - Metrics and Logs for the Demo API",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "📊 Overview — Real-Time Summary",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "workshop-prometheus" },
      "description": "Total HTTP requests per second across all endpoints",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 2,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red",    "value": 100 }
            ]
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "workshop-prometheus" },
          "expr": "sum(rate(http_requests_total[1m]))",
          "instant": true,
          "legendFormat": "req/s",
          "refId": "A"
        }
      ],
      "title": "🚀 Request Rate",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "workshop-prometheus" },
      "description": "Percentage of requests returning 5xx errors. Green < 5%, Red > 15%",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 1,
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red",    "value": 15 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "workshop-prometheus" },
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[1m])) / sum(rate(http_requests_total[1m])) * 100 OR vector(0)",
          "instant": true,
          "legendFormat": "error %",
          "refId": "A"
        }
      ],
      "title": "🚨 Error Rate (5xx)",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "workshop-prometheus" },
      "description": "Requests currently being processed by the API",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red",    "value": 50 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "workshop-prometheus" },
          "expr": "sum(http_active_requests) OR vector(0)",
          "instant": true,
          "legendFormat": "active",
          "refId": "A"
        }
      ],
      "title": "⚡ Active Requests",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "workshop-prometheus" },
      "description": "95th percentile response time. 95% of requests complete faster than this.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 3,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red",    "value": 2.0 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "workshop-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[1m])) by (le))",
          "instant": true,
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "title": "⏱ Response Time P95",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "title": "📈 Traffic Analysis — Requests Over Time",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "workshop-prometheus" },
      "description": "Requests per second broken down by endpoint. Watch this spike when you run k6!",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "requests/sec",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 11,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "workshop-prometheus" },
          "expr": "sum(rate(http_requests_total[1m])) by (route)",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "📊 Request Rate by Endpoint",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "workshop-prometheus" },
      "description": "P50 = median, P95 = 95th percentile, P99 = 99th percentile. The /slow endpoint will be obvious here!",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "response time",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 5,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 12,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "workshop-prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[1m])) by (le, route))",
          "legendFormat": "P50 {{route}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "workshop-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[1m])) by (le, route))",
          "legendFormat": "P95 {{route}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "workshop-prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[1m])) by (le, route))",
          "legendFormat": "P99 {{route}}",
          "refId": "C"
        }
      ],
      "title": "⏱ Response Time Percentiles",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 20,
      "title": "🚨 Errors & HTTP Status Codes",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "workshop-prometheus" },
      "description": "Error percentage per endpoint. /error endpoint should show ~70% error rate.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "error %",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "max": 100,
          "min": 0,
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 21,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "workshop-prometheus" },
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[1m])) by (route) / sum(rate(http_requests_total[1m])) by (route) * 100",
          "legendFormat": "5xx — {{route}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "workshop-prometheus" },
          "expr": "sum(rate(http_requests_total{status_code=~\"4..\"}[1m])) by (route) / sum(rate(http_requests_total[1m])) by (route) * 100",
          "legendFormat": "4xx — {{route}}",
          "refId": "B"
        }
      ],
      "title": "🚨 Error Rate by Endpoint (%)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "workshop-prometheus" },
      "description": "Distribution of HTTP status codes. Healthy APIs should be mostly 200.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "hideFrom": { "legend": false, "tooltip": false, "viz": false }
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "2.." },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "4.." },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "5.." },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 22,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["percent", "value"] },
        "pieType": "donut",
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "workshop-prometheus" },
          "expr": "sum(increase(http_requests_total[5m])) by (status_code)",
          "legendFormat": "HTTP {{status_code}}",
          "refId": "A"
        }
      ],
      "title": "🥧 HTTP Status Code Distribution (last 5m)",
      "type": "piechart"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 30,
      "title": "🖥 System Resources — Node.js Process",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "workshop-prometheus" },
      "description": "Node.js heap memory usage",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 31,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "workshop-prometheus" },
          "expr": "nodejs_process_heap_bytes",
          "legendFormat": "Heap Size",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "workshop-prometheus" },
          "expr": "nodejs_process_resident_memory_bytes",
          "legendFormat": "RSS Memory",
          "refId": "B"
        }
      ],
      "title": "💾 Node.js Heap Memory",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "workshop-prometheus" },
      "description": "Node.js event loop lag — high values mean the server is overloaded",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 32,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "workshop-prometheus" },
          "expr": "nodejs_nodejs_eventloop_lag_seconds",
          "legendFormat": "Event Loop Lag",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "workshop-prometheus" },
          "expr": "nodejs_nodejs_eventloop_lag_max_seconds",
          "legendFormat": "Max Lag",
          "refId": "B"
        }
      ],
      "title": "⚙️ Node.js Event Loop Lag",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 40,
      "title": "📋 Application Logs — Live from Loki",
      "type": "row"
    },

    {
      "datasource": { "type": "loki", "uid": "workshop-loki" },
      "description": "Live logs from the API container. Use the search bar to filter. Try: error | warn | /slow",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 33 },
      "id": 41,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "workshop-loki" },
          "expr": "{job=\"api\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "📋 API Logs (all levels)",
      "type": "logs"
    },

    {
      "datasource": { "type": "loki", "uid": "workshop-loki" },
      "description": "Only ERROR level logs — this is what you check first when something goes wrong",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 45 },
      "id": 42,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "workshop-loki" },
          "expr": "{job=\"api\"} |= `\"level\":\"error\"`",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "🔴 Error Logs Only",
      "type": "logs"
    }

  ],
